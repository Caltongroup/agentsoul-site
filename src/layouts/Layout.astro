---
import '../styles/global.css'
const { title = 'AgentSoul — Your Business. Your AI. Your Box.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AgentSoul — Private, local AI agents for any business. No cloud, no subscriptions, no data leaving your building." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased">
    <slot />
  </body>
</html>
